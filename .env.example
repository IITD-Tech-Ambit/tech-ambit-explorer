# Local development (Vite :5173 → api-gateway :8080)
VITE_API_URL=http://localhost:8080/api
VITE_SEARCH_API_URL=http://localhost:8080/search/api/v1
VITE_CHAT_API_URL=http://localhost:3003/api/v1

# Docker production (via nginx reverse proxy)
# VITE_API_URL=/api
# VITE_SEARCH_API_URL=/search/api/v1
# VITE_CHAT_API_URL=/chat-api/api/v1

# IP/Patents search (SEO-Backend-iitd REST API — not yet proxied through
# api-gateway's gRPC bridge, so it's routed same-origin via the /ip-search-api
# vite dev proxy in vite.config.ts instead of an absolute URL)
VITE_IP_SEARCH_API_URL=/ip-search-api/api/v1

# Research Atlas renderer. Default (unset/true) uses the octree LOD streaming
# renderer backed by MongoDB tiles. Set to false to fall back to the legacy
# monolithic /atlas renderer during the migration window.
# VITE_ATLAS_TILES=true

# Optional: extra Vite allowedHosts for local tunnels (comma-separated).
# Do not commit real hostnames — set locally in .env if needed.
# VITE_DEV_ALLOWED_HOSTS=your-tunnel.example.com